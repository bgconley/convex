# Cortex Infrastructure Environment Variables
# Copy to .env and fill in values: cp .env.example .env

POSTGRES_PASSWORD=changeme_use_a_strong_password

# Host port mappings (avoid conflicts with existing services on GPU server)
# Internal Docker networking is unaffected — containers use service names.
# postgres: 5433 → 5432 (internal)
# redis:    6380 → 6379 (internal)
# embedder: 8082 → 80   (internal)
# api:      8090 → 8080 (internal)
